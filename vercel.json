{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "excludeFiles": "backend/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/openrouter/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/openrouter",
      "dest": "/api/index.py"
    }
  ]
}
