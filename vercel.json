{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "web_frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/openrouter/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/openrouter",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/web_frontend/dist/$1"
    }
  ]
}
