{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "excludeFiles": "backend/**"
      }
    },
    {
      "src": "web_frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "npm run build",
        "installCommand": "npm install"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/openrouter/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/openrouter",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/web_frontend/dist/$1"
    }
  ]
}
