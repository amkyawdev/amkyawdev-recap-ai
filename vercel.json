{
  "version": 2,
  "builds": [
    {
      "src": "api/openrouter.py",
      "use": "@vercel/python",
      "config": {
        "installCommand": "pip3 install -r requirements.txt",
        "buildCommand": "pip3 install -r requirements.txt",
        "outputDirectory": "api"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/openrouter/(.*)",
      "dest": "/api/openrouter.py"
    },
    {
      "src": "/api/openrouter",
      "dest": "/api/openrouter.py"
    }
  ],
  "env": {
    "OPENROUTER_API_KEY": "@openrouter_api_key"
  },
  "framework": null
}
