{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "web_frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/web_frontend/dist/assets/$1"
    },
    {
      "src": "/icon.png",
      "dest": "/web_frontend/dist/icon.png"
    },
    {
      "src": "/(.*)",
      "dest": "/web_frontend/dist/$1"
    }
  ]
}
