{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "excludeFiles": "backend/**"
      }
    },
    {
      "src": "web_frontend/dist/**",
      "use": "@vercel/static"
    },
    {
      "src": "web_frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/openrouter/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/openrouter",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/web_frontend/dist/$1"
    }
  ]
}
