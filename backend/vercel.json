{
  "version": 2,
  "builds": [
    {
      "src": "api/openrouter.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/openrouter/(.*)",
      "dest": "/api/openrouter.py"
    },
    {
      "src": "/api/openrouter",
      "dest": "/api/openrouter.py"
    }
  ],
  "env": {
    "OPENROUTER_API_KEY": "placeholder"
  },
  "buildCommand": "pip install -r requirements",
  "outputDirectory": "api",
  "installCommand": "pip install -r requirements"
}
